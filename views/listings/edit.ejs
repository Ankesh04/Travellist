<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Travellist</title>
</head>
<body>
    <h3>Edit your Listing</h3>
    <form method="POST" action="/listings/<%= showAllListing._id %>?_method=PUT">
        <input name="listing[title]" value="<%= showAllListing.title %>" type="text">
        <br><br>
        <textarea name="listing[description]" ><%= showAllListing.description %></textarea>
        <br><br>
        <input name="listing[image]" value="<%= showAllListing.image %>" type="text">
        <br><br>
        <input name="listing[price]" value="<%= showAllListing.price %>" type="number">
        <br><br>
        <input name="listing[country]" value="<%= showAllListing.country %>" type="text">
        <br><br>
        <input name="listing[location]" value="<%= showAllListing.location %>" type="text">
        <br><br>
        <button>Edit</button>
    </form>
</body>
</html>